{
  "name": "mstroy-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss}\" \"*.{json,js,ts}\""
  },
  "dependencies": {
    "ag-grid-community": "^35.2.0",
    "ag-grid-enterprise": "^35.2.0",
    "ag-grid-vue3": "^35.2.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.5"
  }
}
